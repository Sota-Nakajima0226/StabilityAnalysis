# Copy to `.env` at the repository root.
# `.env` is reserved for machine/environment dependent settings only.

# Which YAML configuration file to load.
# Relative path is resolved from repository root.
APP_CONFIG_YML_PATH=config/config.yml

# Runtime log verbosity only (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# --- Required: SQLite path (repo-relative or absolute) ---
DATABASE_PATH=db/stability_analysis.db

# --- Other env settings (omit to use code defaults) ---

# --- Analysis 9d settings ---
# Debug flag
ANALYSIS_9D_DEBUG=false
# Comma-separated integers
ANALYSIS_9D_TARGET_MODULI_9D_IDS=3
# Optional: worker processes for run_massless_solution.py (default: max(1, cpu_count-1))
# MASSLESS_9D_WORKERS=4

# --- Analysis 8d settings ---
# Debug flag
ANALYSIS_8D_DEBUG=false
# Comma-separated integers
ANALYSIS_8D_TARGET_MODULI_9D_IDS=1,3
ANALYSIS_8D_TARGET_MODULI_8D_IDS=14
# Optional: worker processes for run_moduli.py (default: max(1, cpu_count-1))
# MODULI_8D_WORKERS=4
# Optional: worker processes for run_critical_point.py (default: max(1, cpu_count-1))
# CRITICAL_POINT_8D_WORKERS=4
# Optional: worker processes for run_hessian.py (default: max(1, cpu_count-1))
# HESSIAN_8D_WORKERS=4

# Chunk sizes
ANALYSIS_8D_COSET_CHUNK_SIZE=5000
ANALYSIS_8D_COSMOLOGICAL_CONST_CHUNK_SIZE=5000
ANALYSIS_8D_CRITICAL_POINT_CHUNK_SIZE=5000
ANALYSIS_8D_HESSIAN_CHUNK_SIZE=5000
# Hessian eigenvalue decimals when saving to DB
ANALYSIS_8D_HESSIAN_EIGENVALUE_ROUND_DIGITS=8

